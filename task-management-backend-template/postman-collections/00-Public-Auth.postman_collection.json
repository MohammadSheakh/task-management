{
	"info": {
		"_postman_id": "00-public-auth-collection",
		"name": "00 - Public & Auth (No Auth Required)",
		"description": "Public endpoints and authentication endpoints that don't require authentication.\n\n**Rate Limits**:\n- Login: 5 attempts / 15 minutes\n- Register: 10 / hour\n- Forgot Password: 3 / hour\n- Verify Email: 5 / hour\n\n**Base URL**: {{baseUrl}}/v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Check if the server is running"
					},
					"response": []
				}
			]
		},
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"userEmail\", jsonData.data.user.email);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "register"]
						},
						"description": "Register a new user account\n\n**Rate Limit**: 10 per hour\n\n**Request**:\n- name: User's full name\n- email: Valid email address\n- password: Min 8 characters\n\n**Response**:\n- user: User object\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"accessToken\", jsonData.data.tokens.accessToken);",
									"    pm.environment.set(\"refreshToken\", jsonData.data.tokens.refreshToken);",
									"    pm.environment.set(\"userId\", jsonData.data.user._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"fcmToken\": \"optional-fcm-token-for-push-notifications\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "login"]
						},
						"description": "Login with email and password\n\n**Rate Limit**: 5 attempts per 15 minutes\n\n**Request**:\n- email: User's email\n- password: User's password\n- fcmToken: Optional (for push notifications)\n\n**Response**:\n- user: User object\n- tokens: { accessToken, refreshToken }\n\n**Note**: Access token expires in 15 minutes, refresh token in 7 days"
					},
					"response": []
				},
				{
					"name": "Google Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idToken\": \"google-id-token-from-frontend\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/google-login",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "google-login"]
						},
						"description": "Login with Google OAuth\n\n**Rate Limit**: 5 attempts per 15 minutes\n\n**Request**:\n- idToken: Google ID token from frontend\n\n**Response**:\n- user: User object\n- tokens: { accessToken, refreshToken }"
					},
					"response": []
				},
				{
					"name": "Apple Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identityToken\": \"apple-identity-token\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/apple",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "apple"]
						},
						"description": "Login with Apple OAuth\n\n**Rate Limit**: 5 attempts per 15 minutes\n\n**Request**:\n- identityToken: Apple identity token\n\n**Response**:\n- user: User object\n- tokens: { accessToken, refreshToken }"
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/forgot-password",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "forgot-password"]
						},
						"description": "Request password reset email\n\n**Rate Limit**: 3 per hour\n\n**Request**:\n- email: User's email\n\n**Response**:\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"reset-token-from-email\",\n  \"newPassword\": \"NewSecurePass123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/reset-password",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "reset-password"]
						},
						"description": "Reset password with token from email\n\n**Rate Limit**: 100 per minute\n\n**Request**:\n- token: Reset token from email\n- newPassword: New password (min 8 characters)\n\n**Response**:\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Verify Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/verify-email",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "verify-email"]
						},
						"description": "Verify email with OTP\n\n**Rate Limit**: 5 per hour\n\n**Request**:\n- email: User's email\n- otp: OTP from email\n\n**Response**:\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Resend OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/resend-otp",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "resend-otp"]
						},
						"description": "Resend verification OTP\n\n**Rate Limit**: 100 per minute\n\n**Request**:\n- email: User's email\n\n**Response**:\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"accessToken\", jsonData.data.accessToken);",
									"    pm.environment.set(\"refreshToken\", jsonData.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/auth/refresh-auth",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "refresh-auth"]
						},
						"description": "Refresh access token using refresh token\n\n**Rate Limit**: 100 per minute\n\n**Request**:\n- refreshToken: Valid refresh token\n\n**Response**:\n- accessToken: New access token (15 min)\n- refreshToken: New refresh token (7 days)\n\n**Note**: Refresh tokens are rotated on use"
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "auth", "logout"]
						},
						"description": "Logout user (clears FCM tokens)\n\n**Rate Limit**: 100 per minute\n\n**Response**:\n- message: Success message"
					},
					"response": []
				}
			]
		}
	]
}
