{
	"info": {
		"_postman_id": "01-user-common-collection",
		"name": "01 - User (Common Role)",
		"description": "All endpoints accessible by authenticated users with common role.\n\n**Authentication Required**: Yes\n**Header**: Authorization: Bearer {{accessToken}}\n\n**Rate Limits**:\n- General endpoints: 100 requests / minute\n- Task creation: 20 / hour\n- Profile updates: 100 / minute\n\n**Base URL**: {{baseUrl}}/v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "User Profile",
			"item": [
				{
					"name": "Get My Profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    console.log('Profile:', jsonData.data);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/users/profile",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "profile"]
						},
						"description": "Get current user's profile information\n\n**Response Time**: ~5ms (cached), ~50ms (cache miss)\n**Cache TTL**: 5 minutes\n\n**Response**:\n- name: User's name\n- email: User's email\n- phoneNumber: Phone number\n- profileImage: Profile image URL\n- supportMode: calm/encouraging/logical\n- notificationStyle: gentle/firm/xyz"
					},
					"response": []
				},
				{
					"name": "Update Profile",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe Updated\",\n  \"phoneNumber\": \"+1234567890\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/users/profile-info",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "profile-info"]
						},
						"description": "Update user profile information\n\n**Cache**: Invalidated after update\n\n**Request**:\n- name: Optional\n- phoneNumber: Optional\n\n**Response**:\n- Updated user object"
					},
					"response": []
				},
				{
					"name": "Get Support Mode",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/users/support-mode",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "support-mode"]
						},
						"description": "Get user's support mode preference\n\n**Figma**: profile-permission-account-interface.png\n\n**Response**:\n- supportMode: calm/encouraging/logical\n- notificationStyle: gentle/firm/xyz"
					},
					"response": []
				},
				{
					"name": "Update Support Mode",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"supportMode\": \"encouraging\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/users/support-mode",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "support-mode"]
						},
						"description": "Update user's support mode preference\n\n**Figma**: response-based-on-mode.png\n\n**Options**:\n- calm: Gentle guidance\n- encouraging: Positive energy\n- logical: Fact-based guidance\n\n**Response**:\n- Updated support mode and notification style"
					},
					"response": []
				},
				{
					"name": "Update Notification Style",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"notificationStyle\": \"firm\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/users/notification-style",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "notification-style"]
						},
						"description": "Update user's notification style preference\n\n**Options**:\n- gentle: Soft and non-intrusive\n- firm: Direct and clear\n- xyz: Custom style\n\n**Response**:\n- Updated notification style"
					},
					"response": []
				}
			]
		},
		{
			"name": "Task Management",
			"item": [
				{
					"name": "Create Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Finish homework\",\n  \"description\": \"Complete math homework\",\n  \"taskType\": \"personal\",\n  \"priority\": \"high\",\n  \"status\": \"pending\",\n  \"startTime\": \"2026-03-09T10:00:00Z\",\n  \"dueDate\": \"2026-03-10T23:59:59Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks"]
						},
						"description": "Create a new task\n\n**Rate Limit**: 20 per hour (daily limit: 50 tasks/day)\n\n**Task Types**:\n- personal: For yourself\n- singleAssignment: Assign to one person\n- collaborative: Assign to multiple people\n\n**Priority**: low, medium, high\n\n**Status**: pending, inProgress, completed\n\n**Response**:\n- Created task object"
					},
					"response": []
				},
				{
					"name": "Get My Tasks",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks"]
						},
						"description": "Get all my tasks with filtering\n\n**Query Params**:\n- status: pending/inProgress/completed\n- taskType: personal/singleAssignment/collaborative\n- priority: low/medium/high\n- from: Start date (ISO format)\n- to: End date (ISO format)\n\n**Response**:\n- Array of tasks"
					},
					"response": []
				},
				{
					"name": "Get Tasks Paginated",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/paginate?page=1&limit=20&status=pending",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "paginate"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								},
								{
									"key": "status",
									"value": "pending"
								}
							]
						},
						"description": "Get paginated tasks with advanced filtering\n\n**Query Params**:\n- page: Page number (default: 1)\n- limit: Items per page (default: 20)\n- status: Filter by status\n- taskType: Filter by type\n- priority: Filter by priority\n- from: Start date\n- to: End date\n- sortBy: Sort field\n- populate: Fields to populate\n\n**Response**:\n- docs: Array of tasks\n- totalPages: Total pages\n- page: Current page\n- limit: Items per page"
					},
					"response": []
				},
				{
					"name": "Get Task Statistics",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/statistics",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "statistics"]
						},
						"description": "Get task statistics by status\n\n**Cache TTL**: 5 minutes\n\n**Response**:\n- total: Total tasks\n- pending: Pending count\n- inProgress: In progress count\n- completed: Completed count"
					},
					"response": []
				},
				{
					"name": "Get Daily Progress",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/daily-progress?date=2026-03-08",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "daily-progress"],
							"query": [
								{
									"key": "date",
									"value": "2026-03-08",
									"description": "Optional, defaults to today"
								}
							]
						},
						"description": "Get daily task progress (Figma: home-flow.png)\n\n**Cache TTL**: 2 minutes\n\n**Query Params**:\n- date: Optional (ISO date, defaults to today)\n\n**Response**:\n- date: Date\n- total: Total tasks for the day\n- completed: Completed count\n- pending: Pending count\n- inProgress: In progress count\n- progress: X/Y format\n- tasks: Array of task details"
					},
					"response": []
				},
				{
					"name": "Get Task By ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "{{taskId}}"]
						},
						"description": "Get task details by ID\n\n**Response**:\n- Task object with populated user details"
					},
					"response": []
				},
				{
					"name": "Update Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated task title\",\n  \"description\": \"Updated description\",\n  \"priority\": \"medium\",\n  \"dueDate\": \"2026-03-15T23:59:59Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "{{taskId}}"]
						},
						"description": "Update task details\n\n**Request**:\n- title: Optional\n- description: Optional\n- priority: Optional\n- dueDate: Optional\n\n**Response**:\n- Updated task object"
					},
					"response": []
				},
				{
					"name": "Update Task Status",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"completed\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/{{taskId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "{{taskId}}", "status"]
						},
						"description": "Update task status\n\n**Status Options**:\n- pending\n- inProgress\n- completed\n\n**Response**:\n- Updated task with completedTime (if completed)"
					},
					"response": []
				},
				{
					"name": "Delete Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "tasks", "{{taskId}}"]
						},
						"description": "Soft delete task\n\n**Response**:\n- Deleted task object"
					},
					"response": []
				}
			]
		}
	]
}
