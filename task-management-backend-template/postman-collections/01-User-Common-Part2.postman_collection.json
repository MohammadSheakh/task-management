{
	"info": {
		"_postman_id": "01-user-common-part2",
		"name": "01 - User (Common Role) - Part 2",
		"description": "Continuation of User endpoints: Subtasks, Groups, Notifications, Analytics\n\n**Authentication Required**: Yes\n**Header**: Authorization: Bearer {{accessToken}}\n\n**Base URL**: {{baseUrl}}/v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Subtasks",
			"item": [
				{
					"name": "Create Subtask",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"taskId\": \"{{taskId}}\",\n  \"title\": \"Research topic\",\n  \"description\": \"Research the topic thoroughly\",\n  \"duration\": \"2 hours\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks"]
						},
						"description": "Create a new subtask\n\n**Request**:\n- taskId: Parent task ID\n- title: Subtask title\n- description: Optional\n- duration: Optional (e.g., \"2 hours\")\n\n**Response**:\n- Created subtask object"
					},
					"response": []
				},
				{
					"name": "Get Subtasks for Task",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks/task/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks", "task", "{{taskId}}"]
						},
						"description": "Get all subtasks for a task\n\n**Response**:\n- Array of subtasks"
					},
					"response": []
				},
				{
					"name": "Get Subtask By ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks/{{subtaskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks", "{{subtaskId}}"]
						},
						"description": "Get subtask details by ID\n\n**Response**:\n- Subtask object"
					},
					"response": []
				},
				{
					"name": "Update Subtask",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated subtask title\",\n  \"duration\": \"3 hours\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks/{{subtaskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks", "{{subtaskId}}"]
						},
						"description": "Update subtask details\n\n**Response**:\n- Updated subtask object"
					},
					"response": []
				},
				{
					"name": "Toggle Subtask Status",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks/{{subtaskId}}/toggle-status",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks", "{{subtaskId}}", "toggle-status"]
						},
						"description": "Toggle subtask completion status\n\n**Response**:\n- Updated subtask with isCompleted toggled"
					},
					"response": []
				},
				{
					"name": "Delete Subtask",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subtasks/{{subtaskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subtasks", "{{subtaskId}}"]
						},
						"description": "Delete subtask\n\n**Response**:\n- Deleted subtask object"
					},
					"response": []
				}
			]
		},
		{
			"name": "Groups",
			"item": [
				{
					"name": "Create Group",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Smith Family\",\n  \"description\": \"Our family task management group\",\n  \"visibility\": \"private\",\n  \"maxMembers\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/groups",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "groups"]
						},
						"description": "Create a new group\n\n**Rate Limit**: 5 per hour\n\n**Request**:\n- name: Group name\n- description: Optional\n- visibility: public/private\n- maxMembers: Optional (default: 5)\n\n**Response**:\n- Created group object"
					},
					"response": []
				},
				{
					"name": "Get My Groups",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/groups/my",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "groups", "my"]
						},
						"description": "Get all groups I'm a member of\n\n**Response**:\n- Array of groups"
					},
					"response": []
				},
				{
					"name": "Get Group By ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/groups/{{groupId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "groups", "{{groupId}}"]
						},
						"description": "Get group details by ID\n\n**Response**:\n- Group object with owner details"
					},
					"response": []
				},
				{
					"name": "Update Group",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Group Name\",\n  \"description\": \"Updated description\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/groups/{{groupId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "groups", "{{groupId}}"]
						},
						"description": "Update group details\n\n**Response**:\n- Updated group object"
					},
					"response": []
				},
				{
					"name": "Delete Group",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/groups/{{groupId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "groups", "{{groupId}}"]
						},
						"description": "Soft delete group\n\n**Response**:\n- Deleted group object"
					},
					"response": []
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "Get My Notifications",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/notifications/my?limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "notifications", "my"],
							"query": [
								{
									"key": "limit",
									"value": "20",
									"description": "Number of notifications"
								}
							]
						},
						"description": "Get my notifications\n\n**Response**:\n- Array of notifications"
					},
					"response": []
				},
				{
					"name": "Get Unread Count",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/notifications/unread-count",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "notifications", "unread-count"]
						},
						"description": "Get unread notification count\n\n**Cache TTL**: 30 seconds\n\n**Response**:\n- count: Number of unread notifications"
					},
					"response": []
				},
				{
					"name": "Mark Notification as Read",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/notifications/{{notificationId}}/read",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "notifications", "{{notificationId}}", "read"]
						},
						"description": "Mark notification as read\n\n**Response**:\n- Updated notification"
					},
					"response": []
				},
				{
					"name": "Mark All as Read",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/notifications/read-all",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "notifications", "read-all"]
						},
						"description": "Mark all notifications as read\n\n**Response**:\n- message: Success message"
					},
					"response": []
				},
				{
					"name": "Delete Notification",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/notifications/{{notificationId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "notifications", "{{notificationId}}"]
						},
						"description": "Delete notification\n\n**Response**:\n- Deleted notification object"
					},
					"response": []
				}
			]
		},
		{
			"name": "Analytics",
			"item": [
				{
					"name": "Get User Overview",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/overview",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "overview"]
						},
						"description": "Get complete user analytics overview\n\n**Cache TTL**: 5 minutes\n\n**Response**:\n- overview: { totalTasks, completedTasks, completionRate, currentStreak, longestStreak, productivityScore }\n- today: { totalTasks, completedTasks, progress, completionRate }\n- thisWeek: { totalTasks, completedTasks, completionRate }\n- thisMonth: { totalTasks, completedTasks, completionRate }"
					},
					"response": []
				},
				{
					"name": "Get Daily Progress",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/daily-progress",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "daily-progress"]
						},
						"description": "Get today's task progress\n\n**Cache TTL**: 2 minutes\n\n**Response**:\n- totalTasks\n- completedTasks\n- pendingTasks\n- inProgressTasks\n- progress: X/Y format\n- completionRate"
					},
					"response": []
				},
				{
					"name": "Get Weekly Streak",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/weekly-streak",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "weekly-streak"]
						},
						"description": "Get user's streak data\n\n**Cache TTL**: 15 minutes\n\n**Response**:\n- currentStreak\n- longestStreak\n- streakHistory: Array\n- lastActiveDate"
					},
					"response": []
				},
				{
					"name": "Get Productivity Score",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/productivity-score",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "productivity-score"]
						},
						"description": "Get productivity score (0-100)\n\n**Cache TTL**: 10 minutes\n\n**Response**:\n- score: 0-100\n- breakdown: { completionRate, streak, tasksCompleted, onTimeCompletion }\n- trend: up/down/stable\n- percentile: User's percentile"
					},
					"response": []
				},
				{
					"name": "Get Completion Rate",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/completion-rate?range=thisWeek",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "completion-rate"],
							"query": [
								{
									"key": "range",
									"value": "thisWeek",
									"description": "today/thisWeek/thisMonth/thisYear"
								}
							]
						},
						"description": "Get completion rate analytics\n\n**Cache TTL**: 10 minutes\n\n**Query Params**:\n- range: today/thisWeek/thisMonth/thisYear\n\n**Response**:\n- overall: Overall completion rate\n- byTimeRange: { today, thisWeek, thisMonth, thisYear }\n- trend: { direction, percentageChange, period }"
					},
					"response": []
				},
				{
					"name": "Get Task Statistics",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/task-statistics",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "task-statistics"]
						},
						"description": "Get task statistics\n\n**Response**:\n- totalTasks\n- byStatus: { pending, inProgress, completed }\n- byPriority: { low, medium, high }\n- byTaskType: { personal, singleAssignment, collaborative }"
					},
					"response": []
				},
				{
					"name": "Get Trend Analytics",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/analytics/user/my/trend?range=thisWeek",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "analytics", "user", "my", "trend"],
							"query": [
								{
									"key": "range",
									"value": "thisWeek",
									"description": "today/thisWeek/thisMonth"
								}
							]
						},
						"description": "Get trend analytics\n\n**Query Params**:\n- range: today/thisWeek/thisMonth\n\n**Response**:\n- period: Range\n- data: Array of daily data points\n- summary: { totalCompleted, averagePerDay, bestDay, worstDay }"
					},
					"response": []
				}
			]
		}
	]
}
