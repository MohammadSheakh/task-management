{
	"info": {
		"_postman_id": "02-admin-collection",
		"name": "02 - Admin (Admin Role)",
		"description": "All endpoints accessible by authenticated users with admin role.\n\n**Authentication Required**: Yes (Admin Role)\n**Header**: Authorization: Bearer {{accessToken}}\n\n**Rate Limits**:\n- Admin endpoints: 200 requests / minute\n- User management: 100 / minute\n\n**Base URL**: {{baseUrl}}/v1",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "User Management",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/users/paginate?page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "paginate"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						},
						"description": "Get all users with pagination and statistics\n\n**Query Params**:\n- page: Page number\n- limit: Items per page\n- name: Search by name\n- email: Search by email\n- createdAt: Filter by date\n\n**Response**:\n- statistics: { totalUser, totalProviders, totalSubAdmin, totalAdmin }\n- docs: Array of users\n- totalPages, page, limit"
					},
					"response": []
				},
