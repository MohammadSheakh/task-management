						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/users/remove-sub-admin/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "users", "remove-sub-admin", "{{userId}}"]
						},
						"description": "Remove sub-admin (soft delete)\n\n**Response**:\n- Updated user object"
					},
					"response": []
				}
			]
