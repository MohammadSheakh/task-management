		{
			"name": "Subscription Management",
			"item": [
				{
					"name": "Get All Subscription Plans",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subscription-plans/paginate?page=1&limit=20",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subscription-plans", "paginate"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						},
						"description": "Get all active subscription plans\n\n**Response**:\n- docs: Array of plans\n- totalPages, page, limit"
					},
					"response": []
				},
				{
					"name": "Create Subscription Plan",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subscriptionName\": \"Individual Subscription\",\n  \"subscriptionType\": \"standard\",\n  \"initialDuration\": \"month\",\n  \"renewalFrequency\": \"monthly\",\n  \"amount\": \"10.99\",\n  \"currency\": \"USD\",\n  \"features\": [\"Single-user account\", \"Create personal tasks\"],\n  \"fullAccessToInteractiveChat\": true,\n  \"canViewCycleInsights\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/subscription-plans",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subscription-plans"]
						},
						"description": "Create new subscription plan (creates Stripe product & price)\n\n**Request**:\n- subscriptionName: Plan name\n- subscriptionType: standard/standardPlus/vise\n- initialDuration: month/year\n- renewalFrequency: monthly/yearly\n- amount: Price (e.g., \"10.99\")\n- currency: USD/EUR/BDT\n- features: Array of features\n- fullAccessToInteractiveChat: Boolean\n- canViewCycleInsights: Boolean\n\n**Response**:\n- Created plan with stripe_product_id and stripe_price_id"
					},
					"response": []
				},
				{
					"name": "Update Subscription Plan",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"subscriptionName\": \"Updated Plan Name\",\n  \"amount\": \"15.99\",\n  \"features\": [\"Updated feature 1\", \"Updated feature 2\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/v1/subscription-plans/{{planId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subscription-plans", "{{planId}}"]
						},
						"description": "Update subscription plan\n\n**Request**:\n- subscriptionName: Optional\n- amount: Optional\n- features: Optional\n\n**Response**:\n- Updated plan object"
					},
					"response": []
				},
				{
					"name": "Delete Subscription Plan",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/subscription-plans/{{planId}}",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "subscription-plans", "{{planId}}"]
						},
						"description": "Soft delete subscription plan\n\n**Response**:\n- Deleted plan object"
					},
					"response": []
				},
				{
					"name": "Get All User Subscriptions",
