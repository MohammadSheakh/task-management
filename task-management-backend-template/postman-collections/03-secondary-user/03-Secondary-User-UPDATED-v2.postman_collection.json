						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"My Personal Task\",\n  \"description\": \"Task for myself only\",\n  \"taskType\": \"personal\",\n  \"priority\": \"medium\",\n  \"startTime\": \"2026-03-17T10:00:00.000Z\",\n  \"scheduledTime\": \"10:00 AM\"\n}"
