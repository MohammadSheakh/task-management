						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Family Room Cleanup\",\n  \"description\": \"Clean the living room together\",\n  \"taskType\": \"collaborative\",\n  \"priority\": \"medium\",\n  \"startTime\": \"2026-03-17T16:00:00.000Z\",\n  \"scheduledTime\": \"4:00 PM\",\n  \"assignedUserIds\": [\n    \":childUserId1\",\n    \":childUserId2\"\n  ]\n}"
						},
