flowchart LR
    %% ===========================================
    %% ANALYTICS MODULE - DATA FLOW (v2.0)
    %% Updated: 12-03-26
    %% ===========================================

    subgraph Sources["📊 Data Sources<br/>(Other Modules)"]
        S1[User Module<br/>User Data]
        S2[Task Module<br/>Task Data]
        S3[childrenBusinessUser ⭐<br/>Family Data]
        S4[TaskProgress ⭐<br/>Progress Data]
        S5[Notification<br/>Activity Data]
        S6[Subscription<br/>Revenue Data]
    end

    subgraph Aggregation["⚙️ Aggregation Layer"]
        A1[chartAggregation.service ⭐<br/>10 Chart Endpoints]
        A2[groupAnalytics.service<br/>Family Analytics]
        A3[userAnalytics.service<br/>User Analytics]
        A4[adminAnalytics.service<br/>Admin Analytics]
        A5[scheduledAnalytics.service<br/>Pre-computation]
    end

    subgraph Cache["🔴 Cache Layer<br/>(Redis)"]
        C1[Chart Cache ⭐<br/>5 min TTL]
        C2[Family Cache<br/>5 min TTL]
        C3[User Cache<br/>5 min TTL]
        C4[Admin Cache<br/>10 min TTL]
        C5[Socket.IO State ⭐<br/>1 min TTL]
    end

    subgraph RealTime["⚡ Real-Time Layer ⭐ NEW!"]
        R1[Socket.IO Server]
        R2[Redis Adapter]
        R3[Family Rooms]
        R4[Events<br/>group:activity<br/>task-progress:*]
    end

    subgraph Response["📤 Response Layer"]
        D1[Chart.js Format ⭐<br/>labels[], datasets[]]
        D2[Family Overview<br/>children[], stats[]]
        D3[User Overview<br/>streak, score, rate]
        D4[Admin Dashboard<br/>metrics, growth, revenue]
    end

    subgraph Frontend["🖥️ Frontend Layer"]
        F1[Flutter App<br/>Chart.js Widget]
        F2[Parent Dashboard<br/>Real-Time Feed]
        F3[Admin Dashboard<br/>Platform Charts]
    end

    %% Data Sources to Aggregation
    S1 --> A1
    S1 --> A2
    S1 --> A3
    S1 --> A4
    S2 --> A1
    S2 --> A2
    S2 --> A3
    S2 --> A4
    S3 --> A1
    S3 --> A2
    S4 --> A1
    S4 --> A2
    S4 --> A3
    S5 --> A2
    S6 --> A1
    S6 --> A4

    %% Aggregation to Cache
    A1 -.->|Check| C1
    A2 -.->|Check| C2
    A3 -.->|Check| C3
    A4 -.->|Check| C4

    %% Cache Hit/Miss Flow
    C1 -->|Hit| A1
    C2 -->|Hit| A2
    C3 -->|Hit| A3
    C4 -->|Hit| A4

    C1 -->|Miss| A1
    C2 -->|Miss| A2
    C3 -->|Miss| A3
    C4 -->|Miss| A4

    %% Aggregation to Response
    A1 --> D1
    A2 --> D2
    A3 --> D3
    A4 --> D4

    %% Real-Time Integration ⭐
    A2 -.->|Broadcast| R1
    A4 -.->|Broadcast| R1
    R1 --> R2
    R2 --> R3
    R2 --> R4
    R1 -.->|State| C5

    %% Response to Frontend
    D1 --> F1
    D1 --> F3
    D2 --> F2
    D3 --> F1
    D4 --> F3

    %% Real-Time to Frontend ⭐
    R1 -.->|Push| F2
    R1 -.->|Push| F3

    %% Scheduled Jobs
    A5 --> C1
    A5 --> C2
    A5 --> C4

    %% Styling
    style Sources fill:#e3f2fd,stroke:#1565c0,color:#000
    style Aggregation fill:#e8f5e9,stroke:#2e7d32,color:#000
    style Cache fill:#ffe0b2,stroke:#e65100,color:#000
    style RealTime fill:#fff9c4,stroke:#f9a825,color:#000
    style Response fill:#f3e5f5,stroke:#7b1fa2,color:#000
    style Frontend fill:#e0f7fa,stroke:#006064,color:#000

    style A1 fill:#c8e6c9,stroke:#2e7d32
    style D1 fill:#c8e6c9,stroke:#2e7d32
    style R1 fill:#fff176,color:#000
    style C1 fill:#ffcc80,color:#000
    style C5 fill:#ffcc80,color:#000
