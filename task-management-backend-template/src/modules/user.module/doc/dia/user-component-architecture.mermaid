    UserService --> GenericService
    UserService --> PaginationService

    UserRoute --> AuthMiddleware
    ProfileRoute --> AuthMiddleware
    DevicesRoute --> AuthMiddleware
    RoleDataRoute --> AuthMiddleware
    OAuthRoute --> RateLimitMiddleware

    UserService --> Redis
    UserService --> MongoDB
    UserService --> EmailService
    DevicesService --> FCM
    OAuthService --> GoogleOAuth
    OAuthService --> AppleOAuth

    UserModel --> MongoDB
