flowchart TB
    subgraph Client["Client Layer"]
        Flutter[Flutter App]
        Web[Task Management Website]
    end

    subgraph LB["Load Balancer"]
        NGINX[NGINX Reverse Proxy]
    end

    subgraph AppServer["Application Servers - Stateless"]
        subgraph UserModule["User Module"]
            UserRoute[user.route.ts]
            UserController[user.controller.ts]
            UserService[user.service.ts]
            UserModel[user.model.ts]
        end

        subgraph ProfileModule["UserProfile Module"]
            ProfileRoute[userProfile.route.ts]
            ProfileController[userProfile.controller.ts]
            ProfileService[userProfile.service.ts]
            ProfileModel[userProfile.model.ts]
        end

        subgraph DeviceModule["UserDevices Module"]
            DeviceRoute[userDevices.route.ts]
            DeviceController[userDevices.controller.ts]
            DeviceService[userDevices.service.ts]
            DeviceModel[userDevices.model.ts]
        end

        subgraph RoleModule["UserRoleData Module"]
            RoleRoute[userRoleData.route.ts]
            RoleController[userRoleData.controller.ts]
            RoleService[userRoleData.service.ts]
            RoleModel[userRoleData.model.ts]
        end

        subgraph OAuthModule["OAuthAccount Module"]
            OAuthRoute[oauthAccount.route.ts]
            OAuthController[oauthAccount.controller.ts]
            OAuthService[oauthAccount.service.ts]
            OAuthModel[oauthAccount.model.ts]
        end
    end

    subgraph Cache["Redis Cache Layer"]
        UserCache[User Cache<br/>TTL: 15 min]
        ProfileCache[Profile Cache<br/>TTL: 15 min]
        SessionCache[Session Cache<br/>TTL: 7 days]
        RateLimitCache[Rate Limit Counters]
    end

    subgraph DB["Database Layer"]
        MongoDB[(MongoDB Atlas)]
        UserCol[User Collection]
        ProfileCol[UserProfile Collection]
        DeviceCol[UserDevices Collection]
        RoleCol[UserRoleData Collection]
        OAuthCol[OAuthAccount Collection]
    end

    subgraph External["External Services"]
        Google[Google OAuth]
        Apple[Apple Sign-In]
        EmailService[Email Service]
        FCM[Firebase Cloud Messaging]
    end

    Flutter --> NGINX
    Web --> NGINX
    NGINX --> UserRoute
    NGINX --> ProfileRoute
    NGINX --> DeviceRoute
    NGINX --> RoleRoute
    NGINX --> OAuthRoute

    UserRoute --> UserController
    UserController --> UserService
    UserService --> UserCache
    UserService --> UserModel

    ProfileRoute --> ProfileController
    ProfileController --> ProfileService
    ProfileService --> ProfileCache
    ProfileService --> ProfileModel

    DeviceRoute --> DeviceController
    DeviceController --> DeviceService
    DeviceService --> DeviceModel

    RoleRoute --> RoleController
    RoleController --> RoleService
    RoleService --> RoleModel

    OAuthRoute --> OAuthController
    OAuthController --> OAuthService
    OAuthService --> OAuthModel

    UserCache <--> MongoDB
    ProfileCache <--> MongoDB
    SessionCache <--> MongoDB

    UserModel --> UserCol
    ProfileModel --> ProfileCol
    DeviceModel --> DeviceCol
    RoleModel --> RoleCol
    OAuthModel --> OAuthCol

    OAuthService --> Google
    OAuthService --> Apple
    UserService --> EmailService
    DeviceService --> FCM
