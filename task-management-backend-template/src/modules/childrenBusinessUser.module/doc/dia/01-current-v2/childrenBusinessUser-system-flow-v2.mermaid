flowchart LR
    %% ===========================================
    %% CHILDREN BUSINESS USER MODULE - SYSTEM FLOW (v2.0)
    %% Updated: 12-03-26
    %% ===========================================

    subgraph Sources["📊 Data Sources<br/>(Other Modules)"]
        S1[User Module<br/>User Data]
        S2[Subscription Module<br/>Plan Limits]
        S3[Task Module<br/>Task Data]
        S4[Notification<br/>Activity Data]
    end

    subgraph Aggregation["⚙️ Aggregation Layer"]
        A1[childrenBusinessUser.service ⭐<br/>with Socket.IO]
    end

    subgraph Cache["🔴 Cache Layer<br/>(Redis)"]
        C1[Family Cache<br/>10 min TTL]
        C2[Secondary User Cache<br/>15 min TTL]
        C3[Socket.IO State ⭐<br/>1 min TTL]
    end

    subgraph RealTime["⚡ Real-Time Layer ⭐ NEW!"]
        R1[Socket.IO Server]
        R2[Redis Adapter]
        R3[Family Rooms]
        R4[Events<br/>group:activity<br/>permission_changed]
    end

    subgraph Response["📤 Response Layer"]
        D1[Family Overview<br/>children[], stats[]]
        D2[Parent Information<br/>parent data]
        D3[Secondary Status<br/>isSecondaryUser]
        D4[Real-Time Events ⭐<br/>activity, permissions]
    end

    subgraph Frontend["🖥️ Frontend Layer"]
        F1[Parent Dashboard<br/>Family Management]
        F2[Child App<br/>Task Creation]
        F3[Real-Time Feed ⭐<br/>Activity Updates]
    end

    %% Data Sources to Aggregation
    S1 --> A1
    S2 --> A1
    S3 --> A1
    S4 --> A1

    %% Aggregation to Cache
    A1 -.->|Check| C1
    A1 -.->|Check| C2
    A1 -.->|Check| C3

    %% Cache Hit/Miss Flow
    C1 -->|Hit| A1
    C2 -->|Hit| A1
    C3 -->|Hit| A1

    C1 -->|Miss| A1
    C2 -->|Miss| A1
    C3 -->|Miss| A1

    %% Aggregation to Response
    A1 --> D1
    A1 --> D2
    A1 --> D3
    A1 --> D4

    %% Real-Time Integration ⭐
    A1 -.->|Broadcast| R1
    R1 --> R2
    R2 --> R3
    R2 --> R4
    R1 -.->|State| C3

    %% Response to Frontend
    D1 --> F1
    D2 --> F2
    D3 --> F2
    D4 --> F3

    %% Real-Time to Frontend ⭐
    R1 -.->|Push| F3

    %% Styling
    style Sources fill:#e3f2fd,stroke:#1565c0,color:#000
    style Aggregation fill:#e8f5e9,stroke:#2e7d32,color:#000
    style Cache fill:#ffe0b2,stroke:#e65100,color:#000
    style RealTime fill:#fff9c4,stroke:#f9a825,color:#000
    style Response fill:#f3e5f5,stroke:#7b1fa2,color:#000
    style Frontend fill:#e0f7fa,stroke:#006064,color:#000

    style A1 fill:#c8e6c9,stroke:#2e7d32
    style R1 fill:#fff176,color:#000
    style C3 fill:#ffcc80,color:#000
