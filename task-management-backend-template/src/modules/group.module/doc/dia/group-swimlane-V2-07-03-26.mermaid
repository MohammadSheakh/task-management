flowchart TD
    subgraph User["👤 Group Owner/Admin"]
        Start([Start]) --> CreateGroup[Create Group]
        CreateGroup --> InviteMembers[Invite Members]
        InviteMembers --> ViewMembers[View Members]
        ViewMembers --> ManageRoles[Manage Member Roles]
        ManageRoles --> RemoveMember[Remove Member]
        RemoveMember --> DeleteGroup[Delete Group]
    end

    subgraph Member["👥 Group Member"]
        ReceiveInvite[Receive Invitation] --> AcceptInvite[Accept Invitation]
        AcceptInvite --> ViewGroup[View Group Details]
        ViewGroup --> Participate[Participate in Group]
        Participate --> LeaveGroup[Leave Group]
    end

    subgraph System["⚙️ System"]
        CreateGroup --> ValidateName[Validate Group Name]
        ValidateName --> SaveGroup[Save Group Document]
        SaveGroup --> CreateOwnerMembership[Create Owner Membership]
        CreateOwnerMembership --> CacheGroup[Cache Group Data]
        
        InviteMembers --> CheckMemberLimit[Check Member Limit]
        CheckMemberLimit --> CreateInvitation[Create Invitation]
        CreateInvitation --> QueueEmail[Queue Email Job]
        QueueEmail --> SendEmail[Send Invitation Email]
        SendEmail --> SendNotification[Send In-App Notification]
        
        AcceptInvite --> ValidateInvitation[Validate Invitation]
        ValidateInvitation --> AddMember[Add Member to Group]
        AddMember --> UpdateCache[Invalidate Cache]
        UpdateCache --> NotifyOwner[Notify Owner]
        
        ViewMembers --> CheckCache{Cache Hit?}
        CheckCache -->|No| QueryDB[Query Members from DB]
        QueryDB --> CacheResult[Cache Results 5min]
        CheckCache -->|Yes| ReturnCached[Return Cached Data]
        CacheResult --> ReturnMembers[Return Member List]
        ReturnCached --> ReturnMembers
        
        ManageRoles --> CheckOwnerPerm{Is Owner?}
        CheckOwnerPerm -->|Yes| UpdateRole[Update Member Role]
        UpdateRole --> NotifyMember[Notify Member of Role Change]
        
        RemoveMember --> CheckPerm{Is Owner/Admin?}
        CheckPerm -->|Yes| SoftDeleteMember[Soft Delete Membership]
        SoftDeleteMember --> UpdateMemberCount[Update Member Count]
        UpdateMemberCount --> NotifyRemoved[Notify Removed Member]
        
        DeleteGroup --> VerifyOwner{Is Owner?}
        VerifyOwner -->|Yes| ArchiveMemberships[Archive All Memberships]
        ArchiveMemberships --> CancelInvitations[Cancel Pending Invitations]
        CancelInvitations --> ClearCache[Clear Cache]
        ClearCache --> End([End])
    end

    ReceiveInvite -.->|Email| SendEmail
    NotifyOwner -.->|Notification| User
    NotifyMember -.->|Notification| Member
    NotifyRemoved -.->|Notification| Member
    LeaveGroup --> CheckNotOwner{Is Not Owner?}
    CheckNotOwner -->|Yes| SoftDeleteMember

    %% Styling
    style User fill:#E3F2FD,stroke:#1976D2,stroke-width:3px
    style Member fill:#E8F5E9,stroke:#388E3C,stroke-width:3px
    style System fill:#FFF3E0,stroke:#F57C00,stroke-width:3px
