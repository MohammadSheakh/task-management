---
title: Group Module - System Architecture Diagram
description: High-level system architecture showing all components and their relationships
date: 07-03-26
---

flowchart TB
    subgraph Client["Client Layer"]
        WebApp[Web Application<br/>React/Next.js]
        MobileApp[Mobile Application<br/>Flutter]
        AdminPanel[Admin Panel]
    end
    
    subgraph API["API Gateway Layer"]
        LoadBalancer[Load Balancer]
        APIGateway[API Gateway<br/>Rate Limiting, Auth]
    end
    
    subgraph Services["Service Layer"]
        GroupService[Group Service<br/>group.service.ts]
        MemberService[Member Service<br/>groupMember.service.ts]
        InvitationService[Invitation Service<br/>groupInvitation.service.ts]
        TaskService[Task Service<br/>task.service.ts]
        NotificationService[Notification Service<br/>notification.service.ts]
    end
    
    subgraph Controllers["Controller Layer"]
        GroupController[Group Controller<br/>group.controller.ts]
        MemberController[Member Controller<br/>groupMember.controller.ts]
        InvitationController[Invitation Controller<br/>groupInvitation.controller.ts]
    end
    
    subgraph Middleware["Middleware Layer"]
        AuthMiddleware[Auth Middleware]
        PermissionMiddleware[Permission Middleware]
        ValidationMiddleware[Validation Middleware]
        RateLimitMiddleware[Rate Limit Middleware]
    end
    
    subgraph BusinessLogic["Business Logic"]
        GroupLogic[Group Business Logic<br/>- Create/Update/Delete<br/>- Member Management<br/>- Permissions]
        MemberLogic[Member Business Logic<br/>- Join/Leave<br/>- Role Management<br/>- Activity Tracking]
        InvitationLogic[Invitation Logic<br/>- Send Invites<br/>- Track Status<br/>- Expiry Handling]
    end
    
    subgraph Data["Data Layer"]
        MongoDB[(MongoDB<br/>Primary Database)]
        Redis[(Redis<br/>Cache Layer)]
        BullMQ[(BullMQ<br/>Job Queue)]
    end
    
    subgraph Collections["MongoDB Collections"]
        Groups[groups Collection]
        GroupMembers[groupmembers Collection]
        GroupInvitations[groupinvitations Collection]
        Tasks[tasks Collection]
        Users[users Collection]
    end
    
    subgraph External["External Services"]
        EmailService[Email Service<br/>SendGrid/SES]
        PushNotification[Push Notification<br/>FCM/APNs]
        FileStorage[File Storage<br/>AWS S3/Cloudinary]
    end
    
    %% Client to API
    WebApp --> LoadBalancer
    MobileApp --> LoadBalancer
    AdminPanel --> LoadBalancer
    LoadBalancer --> APIGateway
    
    %% API to Controllers
    APIGateway --> GroupController
    APIGateway --> MemberController
    APIGateway --> InvitationController
    
    %% Middleware Flow
    GroupController --> AuthMiddleware
    MemberController --> AuthMiddleware
    InvitationController --> AuthMiddleware
    
    AuthMiddleware --> PermissionMiddleware
    PermissionMiddleware --> ValidationMiddleware
    ValidationMiddleware --> RateLimitMiddleware
    
    %% Controllers to Services
    RateLimitMiddleware --> GroupService
    RateLimitMiddleware --> MemberService
    RateLimitMiddleware --> InvitationService
    
    %% Services to Business Logic
    GroupService --> GroupLogic
    MemberService --> MemberLogic
    InvitationService --> InvitationLogic
    
    %% Business Logic to Data
    GroupLogic --> MongoDB
    MemberLogic --> MongoDB
    InvitationLogic --> MongoDB
    
    %% Caching
    GroupLogic -.-> Redis
    MemberLogic -.-> Redis
    
    %% Job Queue
    InvitationLogic -.-> BullMQ
    NotificationService -.-> BullMQ
    
    %% External Services
    BullMQ --> EmailService
    BullMQ --> PushNotification
    GroupLogic --> FileStorage
    
    %% Task Integration
    GroupLogic --> TaskService
    TaskService --> Tasks
    
    %% Notification Integration
    GroupLogic --> NotificationService
    MemberLogic --> NotificationService
    InvitationLogic --> NotificationService
    
    %% Data Relationships
    Groups -.-> GroupMembers
    Groups -.-> GroupInvitations
    GroupMembers -.-> Users
    GroupInvitations -.-> Users
    
    %% Styling
    style Client fill:#E3F2FD
    style API fill:#FFF3E0
    style Services fill:#E8F5E9
    style Controllers fill:#F3E5F5
    style Middleware fill:#FFEBEE
    style BusinessLogic fill:#E0F7FA
    style Data fill:#F1F8E9
    style Collections fill:#FFF8E1
    style External fill:#FCE4EC
