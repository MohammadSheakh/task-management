erDiagram
    USER ||--o{ GROUP_MEMBER : "belongs to"
    GROUP ||--o{ GROUP_MEMBER : "has members"
    GROUP ||--o{ GROUP_INVITATION : "sends invitations"
    USER ||--o{ GROUP_INVITATION : "receives/sends"
    GROUP ||--o{ TASK : "owns tasks"
    USER ||--o{ TASK : "creates/assigned"

    USER {
        ObjectId _id
        String name
        String email
        String role
    }

    GROUP {
        ObjectId _id
        String name
        String description
        ObjectId ownerUserId
        String visibility
        Integer maxMembers
        Integer currentMemberCount
        Boolean isDeleted
        DateTime createdAt
        DateTime updatedAt
    }

    GROUP_MEMBER {
        ObjectId _id
        ObjectId groupId
        ObjectId userId
        String role
        String status
        DateTime joinedAt
        Boolean isDeleted
    }

    GROUP_INVITATION {
        ObjectId _id
        ObjectId groupId
        ObjectId invitedByUserId
        ObjectId invitedUserId
        String email
        String status
        String token
        DateTime expiresAt
        Boolean isDeleted
    }

    TASK {
        ObjectId _id
        String title
        String description
        ObjectId groupId
        ObjectId ownerUserId
        String status
        DateTime createdAt
    }
