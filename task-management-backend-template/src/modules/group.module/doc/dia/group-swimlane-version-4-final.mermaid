flowchart TD
    subgraph PrimaryUser["👤 Primary User Parent/Teacher"]
        Start([Start]) --> ViewDashboard[View Team Dashboard]
        ViewDashboard --> ViewTeamMembers[View Team Members]
        
        %% Create Member Flow
        ViewTeamMembers --> CreateMember[Create Member]
        CreateMember --> FillDetails[Fill Member Details]
        FillDetails --> SetSupportMode[Set Support Mode<br/>Calm/Encouraging/Logical]
        SetSupportMode --> CreateAccount[Create Account]
        
        %% Edit Member Flow
        ViewTeamMembers --> EditMember[Edit Member]
        EditMember --> UpdateProfile[Update Profile]
        UpdateProfile --> ChangeSupportMode[Change Support Mode]
        
        %% Task Management Flow
        ViewDashboard --> TaskManagement[Task Management]
        TaskManagement --> CreateTask[Create Task]
        CreateTask --> TaskType{Task Type?}
        TaskType -->|Single Assignment| AssignOne[Assign to One Member]
        TaskType -->|Collaborative| AssignMultiple[Assign to Multiple]
        TaskType -->|Personal| AssignSelf[Assign to Self]
        
        %% Permissions Flow
        ViewDashboard --> ManagePermissions[Manage Permissions]
        ManagePermissions --> ToggleTasks[Toggle: Allow Secondary Tasks]
        ToggleTasks --> GrantPermission[Grant Individual Permissions]
        
        %% Live Activity
        ViewDashboard --> ViewLiveActivity[View Live Activity Feed]
    end

    subgraph SecondaryUser["👥 Secondary User Child/Member"]
        Onboard["Onboarding: Choose Support Style"] --> SelectMode[Select Mode]
        SelectMode --> Home[View Home Screen]
        
        %% Home Flow
        Home --> ViewDailyProgress[View Daily Progress<br/>e.g., 1/5 tasks]
        ViewDailyProgress --> ViewTasks[View Assigned Tasks]
        ViewTasks --> StartTask[Start Task]
        StartTask --> WorkOnTask[Work on Task]
        WorkOnTask --> AddSubtask[Add Subtasks]
        AddSubtask --> CompleteSubtask[Complete Subtasks]
        CompleteSubtask --> MarkComplete[Mark Task Complete]
        
        %% Permission-Based Task Creation
        Home --> CheckPermission{Has Task Permission?}
        CheckPermission -->|Yes| CreateTaskSecondary[Create Task for Others]
        CheckPermission -->|No| CreatePersonalOnly[Create Personal Task<br/>Self Only]
        
        %% Status Flow
        ViewTasks --> ViewStatus[View Status Section]
        ViewStatus --> FilterStatus[Filter: Pending/In Progress/Completed]
        FilterStatus --> ViewTaskDetails[View Task Details]
        ViewTaskDetails --> TrackSubtasks[Track Subtask Progress]
        
        %% Profile Flow
        SecondaryUser --> ViewProfile[View Profile]
        ViewProfile --> EditInfo[Edit Personal Information]
        EditInfo --> ChangeMode[Change Support Mode]
        ChangeMode --> SetNotificationStyle[Set Notification Style<br/>Gentle/Firm/XYZ]
        SetNotificationStyle --> SavePref[Save Preference]
    end

    subgraph System["⚙️ System"]
        %% Member Creation Flow
        CreateAccount --> ValidateEmail[Validate Email Uniqueness]
        ValidateEmail --> CreateUserProfile[Create UserProfile]
        CreateUserProfile --> SetPreferences[Set Support Mode & Notification Style]
        SetPreferences --> CreateUser[Create User Account]
        CreateUser --> AddToGroup[Add to Group as Member]
        AddToGroup --> UpdateCount[Update Member Count]
        UpdateCount --> InvalidateCache[Invalidate Redis Cache]
        InvalidateCache --> QueueWelcome[Queue Welcome Email<br/>BullMQ Async]
        
        %% Profile Update Flow
        UpdateProfile --> ValidateUpdater[Validate Updater Permission]
        ValidateUpdater --> UpdateUserFields[Update User Fields]
        UpdateUserFields --> UpdateProfileFields[Update UserProfile Fields]
        UpdateProfileFields --> ReloadUser[Reload User with Profile]
        ReloadUser --> InvalidateCache2[Invalidate Cache]
        
        %% Daily Progress Flow
        ViewDailyProgress --> GetTasks[Get Tasks for Date Range]
        GetTasks --> CalculateStats[Calculate Statistics<br/>Total/Completed/Pending/InProgress]
        CalculateStats --> BuildTaskList[Build Task List with Subtasks]
        BuildTaskList --> ReturnProgress[Return Progress Object]
        
        %% Live Activity Flow
        MarkComplete --> RecordActivity[Record Activity]
        RecordActivity --> CreateNotification[Create Notification Entry]
        CreateNotification --> AddToFeed[Add to Activity Feed]
        AddToFeed --> NotifyMembers[Notify Group Members]
        NotifyMembers --> UpdateDashboard[Update Dashboard in Real-Time]
        
        %% Task Creation Flow
        AssignOne --> ValidateTask[Validate Task Data]
        ValidateTask --> SaveTask[Save Task to Database]
        SaveTask --> TriggerNotif[Trigger Notification]
        TriggerNotif --> NotifyAssignees[Notify Assignees]
        
        AssignMultiple --> ValidateTask
        AssignSelf --> ValidateTask
        
        %% Permission Flow
        GrantPermission --> UpdatePermissionDB[Update Permission in Database]
        UpdatePermissionDB --> InvalidatePermCache[Invalidate Permission Cache]
        
        %% Activity Types
        CreateNotification --> ActivityType{Activity Type?}
        ActivityType -->|Task Complete| TaskComplete[task_completed]
        ActivityType -->|Task Start| TaskStart[task_started]
        ActivityType -->|Subtask Complete| SubtaskComplete[subtask_completed]
        ActivityType -->|Member Join| MemberJoin[member_joined]
    end

    %% Cross-lane connections
    QueueWelcome -.->|Email| SecondaryUser
    NotifyAssignees -.->|Push Notification| SecondaryUser
    UpdateDashboard -.->|Real-time| PrimaryUser
    NotifyMembers -.->|In-App| PrimaryUser
    
    CreateTaskSecondary --> ValidateTask
    CreatePersonalOnly --> ValidateSelfOnly[Validate: Self Assignment]
    ValidateSelfOnly --> SaveTask

    %% Styling - Matching task-swimlane style
    style PrimaryUser fill:#E3F2FD,stroke:#1976D2,stroke-width:3px
    style SecondaryUser fill:#E8F5E9,stroke:#388E3C,stroke-width:3px
    style System fill:#FFF3E0,stroke:#F57C00,stroke-width:3px
