graph TB
    subgraph frontend["🖥️ Frontend"]
        FlutterApp[Flutter Mobile App]
        WebApp[React Website]
        TaskCreation[Task Creation Screen]
        SuggestionDialog[Suggestion Dialog UI]
    end

    subgraph api_gateway["🔌 API Gateway"]
        LoadBalancer[Load Balancer]
        RateLimiter[Rate Limiter]
        AuthMiddleware[Auth Middleware]
    end

    subgraph backend["⚙️ Backend Services"]
        TaskModule[Task Module]
        PrefSuggestion[⏰ Suggestion Service]
        GroupModule[Group Module]
        NotificationModule[Notification Module]
        UserModule[User Module]
        AttachmentModule[Attachment Module]
    end

    subgraph async["🔄 Async Processing"]
        BullMQ[BullMQ Queues]
        Workers[Background Workers]
        PrefTimeWorker[⏰ Preferred Time Worker]
    end

    subgraph data["💾 Data Layer"]
        MongoDB[MongoDB Database]
        TaskDB[(Task Collection)]
        UserDB[(User Collection)]
        Redis[Redis Cache]
        FileStorage[File Storage]
    end

    FlutterApp --> LoadBalancer
    WebApp --> LoadBalancer

    LoadBalancer --> RateLimiter
    RateLimiter --> AuthMiddleware
    AuthMiddleware --> TaskModule
    AuthMiddleware --> GroupModule
    AuthMiddleware --> NotificationModule
    AuthMiddleware --> UserModule
    AuthMiddleware --> AttachmentModule

    TaskModule --> BullMQ
    GroupModule --> BullMQ
    NotificationModule --> BullMQ

    BullMQ --> Workers
    BullMQ --> PrefTimeWorker

    TaskModule --> MongoDB
    TaskModule --> Redis
    GroupModule --> MongoDB
    GroupModule --> Redis
    NotificationModule --> MongoDB
    NotificationModule --> Redis

    AttachmentModule --> FileStorage

    PrefTimeWorker --> TaskDB
    PrefTimeWorker --> UserDB

    TaskDB -.->|Get completed tasks | PrefTimeWorker
    PrefTimeWorker -.->|Calculate average | PrefTimeWorker
    PrefTimeWorker -.->|Update preferredTime | UserDB

    %% Suggestion Flow
    TaskCreation --> PrefSuggestion
    PrefSuggestion --> UserDB
    UserDB -.->|Get preferredTime | PrefSuggestion
    PrefSuggestion -.->|Return suggestion | TaskCreation
    PrefSuggestion -.->|Generate alternatives | PrefSuggestion

    TaskCreation --> SuggestionDialog
    SuggestionDialog --> FlutterApp

    style PrefTimeWorker fill:#f9f,stroke:#333,stroke-width:2px
    style UserDB fill:#bbf,stroke:#333,stroke-width:2px
    style PrefSuggestion fill:#9ff,stroke:#333,stroke-width:2px
    style SuggestionDialog fill:#ff9,stroke:#333,stroke-width:2px
