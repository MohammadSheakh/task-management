erDiagram
    TASK ||--o{ USER : "creator"
    TASK ||--o{ USER : "assignee"
    TASK ||--o{ SUBTASK : "contains"
    TASK ||--o{ GROUP : "belongs to"
    TASK ||--o{ TASK_REMINDER : "has reminders"
    TASK ||--o{ NOTIFICATION : "triggers"
    TASK ||--o{ ATTACHMENT : "has attachments"

    TASK {
        ObjectId _id PK
        String title
        String description
        ObjectId groupId FK "Reference to group"
        ObjectId createdById FK "Task creator"
        ObjectId assigneeId FK "Assigned user"
        String status "pending|in_progress|under_review|completed|cancelled"
        String priority "low|medium|high|urgent"
        DateTime dueDate "Task deadline"
        DateTime completionDate "When completed"
        String[] tags "Search tags"
        Mixed customFields "Extensibility"
        Int progress "0-100 percentage"
        Boolean isRecurring "Recurring task flag"
        String recurrencePattern "daily|weekly|monthly"
        ObjectId parentTaskId FK "For subtasks"
        Int subTaskCount "Cached count"
        Mixed metadata "Additional data"
        Boolean isDeleted "Soft delete"
        DateTime createdAt "Creation timestamp"
        DateTime updatedAt "Update timestamp"
    }

    SUBTASK {
        ObjectId _id PK
        ObjectId taskId FK "Parent task"
        String title
        String description
        String status "pending|in_progress|completed"
        ObjectId assigneeId FK
        DateTime dueDate
        Int order "Display order"
        Boolean isDeleted
        DateTime createdAt
        DateTime updatedAt
    }

    USER {
        ObjectId _id PK
        String name
        String email
        String role
        String profileImage
    }

    GROUP {
        ObjectId _id PK
        String name
        String description
        ObjectId ownerId FK
        String visibility
        Int memberCount
    }

    TASK_REMINDER {
        ObjectId _id PK
        ObjectId taskId FK
        ObjectId userId FK
        DateTime reminderTime
        String triggerType
        String status
    }

    NOTIFICATION {
        ObjectId _id PK
        ObjectId senderId FK
        ObjectId receiverId FK
        String title
        String type
        String status
    }

    ATTACHMENT {
        ObjectId _id PK
        ObjectId taskId FK
        String fileName
        String fileType
        String fileUrl
        Int fileSize
    }

    %% Indexes
    %% createdById_1_isDeleted_1
    %% assigneeId_1_status_1_isDeleted_1
    %% groupId_1_status_1_isDeleted_1
    %% dueDate_1_status_1_isDeleted_1
    %% status_1_isDeleted_1_createdAt_-1
    %% parentTaskId_1_isDeleted_1_order_1
    %% tags_1_isDeleted_1
    %% text index: title, description
