flowchart TB
    %% ===========================================
    %% TASK PROGRESS MODULE - COMPONENT ARCHITECTURE (v2.0)
    %% Updated: 12-03-26
    %% ===========================================

    subgraph Presentation["🖥️ Presentation Layer"]
        subgraph Flutter["📱 Flutter App"]
            F1[Progress List Screen]
            F2[Progress Detail Widget]
            F3[Progress Bar Widget]
        end

        subgraph Web["💻 Web Dashboard"]
            W1[Progress Component]
            W2[Statistics Component]
            W3[Real-Time Feed]
        end
    end

    subgraph API["🔌 API Layer"]
        subgraph Routes["Routes"]
            R1[taskProgress.route.ts]
        end

        subgraph Middleware["Middleware"]
            M1[Authentication<br/>JWT]
            M2[Rate Limiting]
            M3[Authorization<br/>Role-based]
            M4[Validation<br/>Zod]
        end
    end

    subgraph Business["⚙️ Business Logic Layer"]
        subgraph Controllers["Controllers"]
            C1[taskProgress.controller]
        end

        subgraph Services["Services"]
            S1[taskProgress.service<br/>with Socket.IO ⭐]
        end

        subgraph Helpers["Helpers"]
            H1[Progress Statistics]
            H2[Percentage Calculator]
            H3[Socket.IO Broadcaster ⭐]
            H4[Cache Manager]
        end
    end

    subgraph Data["💾 Data Layer"]
        subgraph MongoDB["MongoDB Collections"]
            D1[TASK_PROGRESS]
            D2[TASK]
            D3[USER]
            D4[SUBTASK]
        end

        subgraph Redis["Redis Cache"]
            DC1[Progress Cache<br/>2-5 min TTL]
            DC2[Socket.IO State ⭐<br/>1 min TTL]
        end
    end

    subgraph RealTime["⚡ Real-Time Layer ⭐ NEW!"]
        RT1[Socket.IO Server]
        RT2[Redis Adapter]
        RT3[Progress Rooms]
        RT4[Family Rooms]
        RT5[Events<br/>progress:updated<br/>progress:completed]
    end

    subgraph Related["🔗 Related Modules"]
        REL1[task.module<br/>Parent task updates]
        REL2[subTask.module<br/>SubTask tracking]
        REL3[notification<br/>Activity feed]
    end

    %% Presentation to API
    F1 --> R1
    F2 --> R1
    F3 --> R1
    W1 --> R1
    W2 --> R1
    W3 --> R1

    %% API Internal Flow
    R1 --> M1
    M1 --> M2
    M2 --> M3
    M3 --> M4

    %% API to Business
    M4 --> C1
    C1 --> S1

    %% Services to Helpers
    S1 --> H1
    S1 --> H2
    S1 --> H3
    S1 --> H4

    %% Business to Data
    S1 --> D1
    S1 --> D2
    S1 --> D3
    S1 --> D4
    S1 -.->|Cache| DC1

    %% Real-Time Integration ⭐
    S1 -.->|Broadcast| RT1
    RT1 --> RT2
    RT2 --> RT3
    RT2 --> RT4
    RT2 --> RT5
    RT1 -.->|State| DC2
    RT1 -.->|Push| W3

    %% Related Modules
    S1 --> REL1
    S1 --> REL2
    S1 --> REL3

    %% Styling
    style Presentation fill:#e3f2fd,stroke:#1565c0,color:#000
    style API fill:#fff3e0,stroke:#e65100,color:#000
    style Business fill:#e8f5e9,stroke:#2e7d32,color:#000
    style Data fill:#fce4ec,stroke:#c2185b,color:#000
    style RealTime fill:#fff9c4,stroke:#f9a825,color:#000
    style Related fill:#e0f7fa,stroke:#006064,color:#000

    style S1 fill:#c8e6c9,stroke:#2e7d32
    style H3 fill:#c8e6c9,stroke:#2e7d32
    style RT1 fill:#fff176,color:#000
    style DC2 fill:#ffcc80,color:#000
